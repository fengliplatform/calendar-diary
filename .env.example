# ─── Clerk ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/calendar
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/settings

# ─── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Pooled connection for app queries (PgBouncer)
DATABASE_URL=
# Direct connection for migrations only (not PgBouncer)
DIRECT_URL=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Safe for client — used for URL generation only, not uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Resend (email notifications) ─────────────────────────────────────────────
# API key from https://resend.com/api-keys (server-only, never prefix NEXT_PUBLIC_)
RESEND_API_KEY=
# Verified sender address — must be on a domain verified in your Resend dashboard
RESEND_FROM_EMAIL=
# Canonical app URL used for email links (no trailing slash)
# e.g. https://daybook.yourfamily.com
NEXT_PUBLIC_APP_URL=
